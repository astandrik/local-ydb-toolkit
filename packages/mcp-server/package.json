{
  "name": "@astandrik/local-ydb-mcp",
  "version": "0.11.0",
  "mcpName": "io.github.astandrik/local-ydb-mcp",
  "description": "Unofficial stdio MCP server for operating local-ydb deployments.",
  "type": "module",
  "bin": {
    "local-ydb-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/astandrik/local-ydb-toolkit.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/astandrik/local-ydb-toolkit/issues"
  },
  "homepage": "https://github.com/astandrik/local-ydb-toolkit#readme",
  "keywords": [
    "local-ydb",
    "ydb",
    "mcp",
    "model-context-protocol",
    "codex"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build -w @local-ydb-toolkit/core && tsc -p tsconfig.json && node ./scripts/vendor-core.mjs",
    "compare:formats": "node ./scripts/compare-formats.mjs",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.3.0",
    "@ydbjs/api": "^6.0.0",
    "@ydbjs/auth": "^6.3.0",
    "@ydbjs/core": "^6.3.0",
    "@ydbjs/error": "^6.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@local-ydb-toolkit/core": "file:../core",
    "gpt-tokenizer": "^3.4.0"
  }
}
